# ── .NET ──────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
.vs/
*.dll
*.pdb
*.exe
TestResults/
coverage.*.xml
*.coverage

# Azure Functions local-only config (NEVER commit; contains keys)
local.settings.json
.azure/
.azurefunctions/

# ── Swift / Xcode ────────────────────────────────────────────────
# `app/Notify.xcodeproj` is the source of truth and is tracked.
# Only per-user state inside it is ignored.
xcuserdata/
*.xcuserstate
DerivedData/
.build/
.swiftpm/
Package.resolved
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# ── macOS / IDE ──────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/

# ── Local dev volumes ────────────────────────────────────────────
.azurite/
.cosmos/
.docker/

# ── Secrets ──────────────────────────────────────────────────────
*.p8
*.p12
*.cer
*.mobileprovision
.env
.env.*
!.env.example
my.pretty.pipeline.code-workspace

# ── Terraform (Cloudflare layer) ─────────────────────────────────
# State lives in Azure Storage via the AzureRM backend; only the local
# `.terraform/` cache + any ad-hoc `*.tfvars` should be ignored. A
# checked-in `*.tfvars.example` is fine — it has placeholders only.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
crash.log

# Guard against `npm install` accidentally run at the repo root. This
# isn't an npm project (the email-ingest Worker that used to live under
# workers/ moved to my.pretty.blender); root-level node_modules /
# package.json / lock is always wrong here and pulls in ~200 MB of
# garbage if not caught.
/node_modules/
/package.json
/package-lock.json

# ── Local scratch (per-machine notes; never commit) ───────────────
todo.md
notes.md
scratch/
